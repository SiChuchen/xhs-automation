# XHS Automation 配置模板
# 请复制并重命名为 .env，然后填入自己的 API Keys

# RunningHub API Keys
RUNNINGHUB_CONSUMER_API_KEY=your_consumer_api_key_here
RUNNINGHUB_ENTERPRISE_API_KEY=your_enterprise_api_key_here

# DeepSeek LLM API (可选)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MiniMax LLM API
MINIMAX_API_KEY=your_minimax_api_key_here

# 飞书告警配置 (可选)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Pexels API (可选)
PEXELS_API_KEY=your_pexels_api_key_here
